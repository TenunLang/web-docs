// Server dokumentasi Tenun — menyajikan markdown apa adanya (ramah LLM/agen).
// Dibangun dengan Tenun (modul-web). Jalankan: tenun run src/server.tenun  (:8080)
//
// Endpoint:
//   GET /            -> ringkasan (content/index.md) sebagai teks
//   GET /daftar      -> daftar nama dokumen (JSON)
//   GET /<nama>      -> isi dokumen markdown sebagai text/plain (mis. /bahasa, /web)

impor "web";

biar DOKUMEN: []teks = [
    "index", "bahasa", "grammar", "builtin",
    "web", "rute", "larik", "tampilan", "json",
    "jaring", "websocket", "socketio",
    "orm", "mysql", "postgres", "redis",
    "auth", "sesi", "mail", "os", "berkas", "proses",
    "belajar", "citra",
    "contoh", "contoh-toko"
];

fungsi cIndex(): teks {
    kembali web_teks(bacaFile("content/index.md"));
}

fungsi cDaftar(): teks {
    biar js: teks = "[";
    untuk i dari 0 sampai panjang(DOKUMEN) {
        kalau i > 0 { js = js + ","; }
        js = js + "\"" + DOKUMEN[i] + "\"";
    }
    js = js + "]";
    kembali web_json(js);
}

fungsi cDokumen(): teks {
    biar nama: teks = web_param("nama");
    kalau akhiriDengan(nama, ".md") {
        nama = potong(nama, 0, panjangTeks(nama) - 3);
    }
    kalau cari(nama, "..") >= 0 {
        web_status(400);
        kembali web_teks("400: nama tidak valid");
    }
    biar path: teks = "content/" + nama + ".md";
    kalau adaFile(path) {
        kembali web_teks(bacaFile(path));
    }
    web_status(404);
    kembali web_teks("404: dokumen '" + nama + "' tidak ada. Lihat /daftar");
}

web_cors("*");
web_get("/", cIndex);
web_get("/daftar", cDaftar);
web_get("/:nama", cDokumen);

fungsi tangani(metode: teks, jalur: teks, badan: teks): teks {
    kembali web_tangani(metode, jalur, badan);
}
layani(8080);
